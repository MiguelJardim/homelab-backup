# Shared Gluetun service configuration
# Global values come from ../.env.global and VPN creds from ../.env.vpn

UPDATER_PERIOD=24h
FIREWALL=on
FIREWALL_OUTBOUND_SUBNETS=100.64.0.0/10,172.28.0.0/16

# Allow inbound traffic for all VPN-routed services sharing this container.
FIREWALL_INPUT_PORTS=8080,8083,6881
FIREWALL_VPN_INPUT_PORTS=8080,8083,6881

OPENVPN_MSSFIX=1368
