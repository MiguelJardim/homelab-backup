# Global Environment Variables Template
# This file should be at /opt/docker/.env.global
# All services can reference these variables via env_file: - ../.env.global
# 
# Each service directory should have a symlink: .env -> ../.env.global
# This allows docker-compose to use these variables for file substitution

# ============================================================================
# USER & GROUP IDENTIFICATION
# ============================================================================
# Used by LinuxServer.io images and services that need specific file permissions
# Find your IDs with: id $USER

PUID=1000
PGID=1000

# ============================================================================
# TIMEZONE
# ============================================================================
# Set your timezone (see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
# Examples: Europe/Lisbon, America/New_York, Asia/Tokyo, UTC

TZ=Europe/Lisbon

# ============================================================================
# DOMAIN CONFIGURATION
# ============================================================================
# Your domain name (used for Caddy reverse proxy subdomains)

DOMAIN=homelab.local

# Caddy TLS certificate paths (adjust if your certs are in a different location)
CADDY_CERT_PATH=/etc/caddy/certs/homelab.local+1.pem
CADDY_CERT_KEY_PATH=/etc/caddy/certs/homelab.local+1-key.pem

# ============================================================================
# VPN CONFIGURATION (Optional - for services using Gluetun)
# ============================================================================
# NordVPN credentials (or your VPN provider)
# Only needed if you have services routing through VPN

# VPN_SERVICE_PROVIDER=nordvpn
# VPN_TYPE=openvpn
# OPENVPN_USER=your_vpn_username
# OPENVPN_PASSWORD=your_vpn_password
# SERVER_CITIES=lisbon  # Comma-separated list: lisbon,paris,london

# ============================================================================
# ADDITIONAL GLOBAL VARIABLES (Optional)
# ============================================================================
# Add any other variables that should be available to all services

# Common paths
# DOCKER_ROOT=/opt/docker
# DATA_ROOT=/opt/docker/data

# Network configuration
# DOCKER_NETWORK=caddy-proxy

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. This file is shared across all services - keep it minimal
# 2. Only include variables that are truly global/common
# 3. Service-specific variables belong in service .env files
# 4. After modifying, restart services to pick up changes
# 5. Variables are available in compose files via ${VARIABLE_NAME}
# 
# ============================================================================

