# Service-Specific Environment Variables Template
# Copy this to your service directory as .env and customize
# 
# NOTE: Common variables (PUID, PGID, TZ, DOMAIN, etc.) are in ../.env.global
# This file is for service-specific configuration only

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================

# Service version/tag (if applicable)
# SERVICE_VERSION=latest
# IMAGE_TAG=v2.1.0

# Service-specific ports (if not using defaults)
# WEBUI_PORT=8080
# API_PORT=8081

# Service URLs (if service needs to know its own URL)
# APP_URL=https://service-name.${DOMAIN}
# PUBLIC_URL=https://service-name.${DOMAIN}
# BASE_URL=https://service-name.${DOMAIN}

# Reverse proxy settings (if behind Caddy/nginx)
# TRUST_PROXY=true
# PROXY_HEADERS=true

# ============================================================================
# DATABASE CONFIGURATION (if service uses a database)
# ============================================================================

# Database type: postgres, mysql, mariadb, sqlite
# DB_TYPE=postgres

# Database connection
# DB_HOST=database  # Container name if in same compose file
# DB_PORT=5432
# DB_NAME=service_db
# DB_USER=service_user
# DB_PASSWORD=change_me_to_secure_password
# DB_DATABASE_NAME=service_db

# Alternative naming (PostgreSQL)
# POSTGRES_USER=service_user
# POSTGRES_PASSWORD=change_me_to_secure_password
# POSTGRES_DB=service_db

# Alternative naming (MySQL/MariaDB)
# MYSQL_ROOT_PASSWORD=change_me_to_secure_password
# MYSQL_DATABASE=service_db
# MYSQL_USER=service_user
# MYSQL_PASSWORD=change_me_to_secure_password

# Database connection string (if service uses connection string)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_CONNECTION_STRING=postgresql://user:password@host:5432/dbname

# ============================================================================
# STORAGE PATHS
# ============================================================================

# Data storage locations (use relative paths for portability)
# UPLOAD_LOCATION=./data
# DATA_LOCATION=./data
# DB_DATA_LOCATION=./postgres
# CONFIG_LOCATION=./config
# DOWNLOADS_LOCATION=./downloads
# CACHE_LOCATION=./cache

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# API keys and secrets (generate secure random strings)
# API_KEY=generate_secure_random_string_here
# SECRET_KEY=generate_secure_random_string_here
# JWT_SECRET=generate_secure_random_string_here
# ENCRYPTION_KEY=generate_secure_random_string_here
# SESSION_SECRET=generate_secure_random_string_here

# Admin credentials (change immediately after first login!)
# ADMIN_USER=admin
# ADMIN_PASSWORD=change_me_immediately
# ADMIN_EMAIL=admin@example.com

# OAuth/SSO configuration (if applicable)
# OAUTH_CLIENT_ID=your_client_id
# OAUTH_CLIENT_SECRET=your_client_secret
# OAUTH_REDIRECT_URI=https://service-name.${DOMAIN}/auth/callback

# ============================================================================
# FEATURE FLAGS & OPTIONS
# ============================================================================

# Enable/disable features
# ENABLE_REGISTRATION=true
# ENABLE_ANALYTICS=false
# DEBUG_MODE=false
# LOG_LEVEL=info  # Options: debug, info, warn, error

# Service-specific options
# MAX_UPLOAD_SIZE=100M
# ALLOWED_ORIGINS=https://service-name.${DOMAIN}
# CORS_ENABLED=true

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Redis (if service uses Redis)
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# SMTP/Email configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@example.com
# SMTP_TLS=true

# External APIs
# API_ENDPOINT=https://api.example.com
# API_KEY=your_api_key_here

# ============================================================================
# ADVANCED CONFIGURATION
# ============================================================================

# Resource limits (if needed)
# MAX_MEMORY=2G
# MAX_CPU=2

# Network configuration
# INTERNAL_PORT=8080
# EXTERNAL_PORT=8080

# File permissions (if not using PUID/PGID from .env.global)
# FILE_UID=1000
# FILE_GID=1000

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. Never commit .env files with real passwords/secrets to version control
# 2. Use strong, unique passwords for each service
# 3. Generate secure random strings for secrets (use: openssl rand -base64 32)
# 4. Use relative paths (./data) for portability
# 5. Reference .env.global variables with ${VARIABLE_NAME} syntax
# 6. Comment out unused variables to keep file clean
# 
# ============================================================================

