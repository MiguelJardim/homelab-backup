# --- Global Snippets for Reusability ---

# TLS Certificate Snippet
(homelab_tls) {
    tls /etc/caddy/certs/homelab.home.arpa+1.pem /etc/caddy/certs/homelab.home.arpa+1-key.pem
}

# --- Service Configurations ---

# Immich
immich.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:2283
}

# Dashy
dashy.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:8091
}

# Pihole
pihole.homelab.home.arpa {
    import homelab_tls
    rewrite / /admin{uri}
    reverse_proxy host.docker.internal:8082
}

# Certificate Authority
ca.homelab.home.arpa {
    root * /etc/caddy/certs
    rewrite * /rootCA.pem
    file_server
}

# Stremio
stremio.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:8080
}

