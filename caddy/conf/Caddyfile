# --- Global Snippets for Reusability ---

# TLS Certificate Snippet
(homelab_tls) {
    tls /etc/caddy/certs/homelab.home.arpa+1.pem /etc/caddy/certs/homelab.home.arpa+1-key.pem
}

# Tailscale forward auth (requires /run/tailscale.nginx-auth.sock mounted in Caddy).
(tailscale_forward_auth) {
    forward_auth unix//run/tailscale.nginx-auth.sock {
        uri /auth
        header_up Remote-Addr {remote_host}
        header_up Remote-Port {remote_port}
        header_up Original-URI {uri}
        copy_headers {
            Tailscale-User>X-Webauth-User
            Tailscale-Name>X-Webauth-Name
            Tailscale-Login>X-Webauth-Login
            Tailscale-Tailnet>X-Webauth-Tailnet
            Tailscale-Profile-Picture>X-Webauth-Profile-Picture
        }
    }
}

# --- Service Configurations ---

# Immich
immich.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:2283
}

# Dashy
dashy.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:8091
}

# Pihole
pihole.homelab.home.arpa {
    import homelab_tls
    rewrite / /admin{uri}
    reverse_proxy host.docker.internal:8082
}

# Certificate Authority
ca.homelab.home.arpa {
    root * /etc/caddy/certs
    rewrite * /rootCA.pem
    file_server
}

