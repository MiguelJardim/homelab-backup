# --- Global Snippets for Reusability ---

# TLS Certificate Snippet
(homelab_tls) {
    tls /etc/caddy/certs/homelab.home.arpa+1.pem /etc/caddy/certs/homelab.home.arpa+1-key.pem
}

# --- Service Configurations ---

# Immich
immich.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:2283
}

# Dashy
dashy.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:8091
}

# Pihole
pihole.homelab.home.arpa {
    import homelab_tls
    rewrite / /admin{uri}
    reverse_proxy host.docker.internal:8082
}

# Certificate Authority
ca.homelab.home.arpa {
    root * /etc/caddy/certs
    rewrite * /rootCA.pem
    file_server
}

# Stremio
stremio.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:8080
}

# qBittorrent
qbittorrent.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:8083
}

# File Browser
filebrowser.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:8081
}

# Arcane
arcane.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:3552
}

# Cursor
cursor.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:8050
}

# AIO Streams
aiostreams.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:3001
}

# Spotify Bundle
slskd.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:5030
}

navidrome.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:4533
}

soulsync.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:8008
}

soulsync-spotify.homelab.home.arpa {
    import homelab_tls
    reverse_proxy host.docker.internal:8888
}

opencode.homelab.home.arpa {
    import homelab_tls
    reverse_proxy 192.168.1.240:4096 {
        # Optional: ensure headers pass through for the Web UI
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
}

ollama.homelab.home.arpa {
    import homelab_tls
    reverse_proxy 100.81.228.59:11435 {
        header_up Host {upstream_hostport}
    }
}
